// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Zed (Default)",
  "cursor_blink": true,
  "git_panel": {
    "tree_view": true,
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 13.0,
  },
  "base_keymap": "VSCode",
  "cursor_shape": "bar",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Monokai Pro (CE)",
  },
  "debugger": {
    "dock": "bottom",
    "show_inline_variable_hints": false,
  },
  "inlay_hints": { "enabled": false, "show_value_hints": false },
  "languages": {
    "Python": {
      "language_servers": ["ty", "!basedpyright", "!pyright", "..."],
    },
  },
}
